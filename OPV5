
local Library = loadstring(Game:HttpGet("https://raw.githubusercontent.com/bloodball/-back-ups-for-libs/main/wizard"))()
local Window = Library:NewWindow("V5")
local Farm = Window:NewSection("Farm")
function takegold()
local Players = game:GetService("Players")
local player = Players.LocalPlayer
local Actors = game:GetService("ReplicatedStorage").Runtime.Actors
local remotes = table.create(250)

for i = 0, 250 do
        local actor = Actors:FindFirstChild("GoldBrickPointActor_" .. i)
        if actor then
            local events = actor:FindFirstChild("Events")
            if events then
                local r = events:FindFirstChild("TakeGold")
                if r then
                    remotes[#remotes + 1] = r
                end
            end
        end
    end

    -- bắn trong cùng 1 frame (không wait, không spawn)
    for i = 0, #remotes do
        local r = remotes[i]
        pcall(function()
            r:FireServer()
        end)
    end
    

    -- gom toàn bộ remote trước
    for i = 0, 250 do
        local actor = Actors:FindFirstChild("GoldPointActor_" .. i)
        if actor then
            local events = actor:FindFirstChild("Events")
            if events then
                local r = events:FindFirstChild("TakeGold")
                if r then
                    remotes[#remotes + 1] = r
                end
            end
        end
    end

    -- bắn trong cùng 1 frame (không wait, không spawn)
    for i = 0, #remotes do
        local r = remotes[i]
        pcall(function()
            r:FireServer()
            r:FireServer(player)
        end)
    end
end
