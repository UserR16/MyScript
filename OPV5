
local Library = loadstring(Game:HttpGet("https://raw.githubusercontent.com/bloodball/-back-ups-for-libs/main/wizard"))()
local Window = Library:NewWindow("V5")
local Farm = Window:NewSection("Farm")
function takecoins()
for i = 0, 200 do
    local actor = game:GetService("ReplicatedStorage").Runtime.Actors:FindFirstChild("GoldPointActor_" .. i)
    
    if actor then
        actor.Events.TakeGold:FireServer()
        actor.Events.TakeGold:FireServer(game:GetService("Players").LOLSCRIPT01)
        task.wait()
    end
end
for i = 0, 200 do
    local actor = game:GetService("ReplicatedStorage").Runtime.Actors:FindFirstChild("GoldBrickPointActor_" .. i)
    
    if actor then
        actor.Events.TakeGold:FireServer()
        actor.Events.TakeGold:FireServer(game:GetService("Players").LOLSCRIPT01)
        task.wait(0.1)
    end
end
end
function takediamonds()
for i = 0, 200 do
    local actor = game:GetService("ReplicatedStorage").Runtime.Actors:FindFirstChild("DiamondPointActor_" .. i)
    
    if actor then
        actor.Events.TakeDiamond:FireServer()
        actor.Events.TakeDiamond:FireServer(game:GetService("Players").LOLSCRIPT01)
        task.wait()
    end
end
end
function addcharge()
for i = 0, 200 do
    local actor = game:GetService("ReplicatedStorage").Runtime.Actors:FindFirstChild("ChargePointActor_" .. i)
    
    if actor then
        actor.Events.AddCharge:FireServer()
      task.wait()
    end
end
end
Farm:CreateToggle("Farm Coins", function(v)
h = v
spawn(function()
while h do
takecoins()
wait()
end
end)
end)
Farm:CreateToggle("Farm Diamond", function(v)
l = v
spawn(function()
while l do
takediamonds()
wait()
end
end)
end)
Farm:CreateToggle("Farm Charge", function(v)
t = v
spawn(function()
while t do
addcharge()
wait()
end
end)
end)
Farm:CreateToggle("Farm Jump", function(v)
k = v
while k do
game:GetService("ReplicatedStorage").Runtime.Actors:WaitForChild("Player_" .. game.Players.LocalPlayer.UserId).Events.Jump:FireServer()
wait(0.1)
end
end)
Farm:CreateToggle("Roll Boost", function(v)
b = v
while b do
game:GetService("ReplicatedStorage").Runtime.Actors:WaitForChild("Player_" .. game.Players.LocalPlayer.UserId).Functions.RollBoost:InvokeServer("JumpPower_1_8")
wait()
end
end)
