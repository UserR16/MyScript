function takecoins()
    list = table.create(#game:GetService("ReplicatedStorage").Runtime.Actors:GetChildren())
    n = 0

    for _, actor in ipairs(game:GetService("ReplicatedStorage").Runtime.Actors:GetChildren()) do
        if actor.Name:find("Gold") and actor:FindFirstChild("Events") then
            n += 1
            list[n] = actor
        end
    end

    for i = 1, n, 25 do
        for j = i, math.min(i + 14, n) do
            list[j].Events.TakeGold:FireServer(game:GetService("Players").LocalPlayer)
        end
        task.wait()
    end
end
